    "Words are validated in your chosen language. You can change this any time in Settings." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wörter werden in deiner gewählten Sprache validiert. Du kannst dies jederzeit in den Einstellungen ändern." } },
