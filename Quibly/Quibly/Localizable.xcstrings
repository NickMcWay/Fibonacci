    "When sliding tiles creates a valid word in a row or column, those tiles clear and you earn points. Longer words score bigger!" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wenn Kacheln ein gültiges Wort bilden, verschwinden sie und du bekommst Punkte. Längere Wörter geben mehr!" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Cuando las fichas formen una palabra válida, se borran y ganas puntos. ¡Las palabras más largas puntúan más!" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Quand les tuiles forment un mot valide, elles disparaissent et vous marquez des points. Les mots longs rapportent plus !" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Als schuivende tegels een geldig woord vormen, verdwijnen ze en verdien je punten. Langere woorden leveren meer op!" } }
      }
    },
    "Word Master" : {
