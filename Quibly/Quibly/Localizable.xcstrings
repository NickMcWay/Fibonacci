        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Les tuiles sont sur une grille. Les lettres rares rapportent plus de points." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Tegels staan op een raster. Zeldzamere letters leveren meer punten op." } }
