    "Swipe left, right, up, or down to slide all tiles in that direction. A new tile spawns after each valid swipe." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wische links, rechts, hoch oder runter. Nach jedem gültigen Wisch erscheint eine neue Kachel." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Desliza izquierda, derecha, arriba o abajo. Aparece una nueva ficha tras cada deslizamiento válido." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Balayez gauche, droite, haut ou bas. Une nouvelle tuile apparaît après chaque balayage valide." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Veeg links, rechts, omhoog of omlaag. Na elke geldige veeg verschijnt een nieuwe tegel." } }
