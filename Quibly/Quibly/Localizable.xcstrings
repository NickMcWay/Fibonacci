    },
    "Tiles sit on a grid. Each tile carries a letter with a point value — rarer letters score more." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Kacheln stehen auf einem Raster. Seltenere Buchstaben geben mehr Punkte." } },
