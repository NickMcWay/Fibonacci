    "Use Hint, Shuffle, Joker, and Bomb to get out of tough spots. Earn coins by clearing tiles to buy more." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Nutze Hinweis, Mischen, Joker und Bombe in schwierigen Situationen. Verdiene Münzen durch das Löschen von Kacheln." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Usa Pista, Mezclar, Comodín y Bomba para salir de situaciones difíciles. Gana monedas borrando fichas." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Utilisez Indice, Mélange, Joker et Bombe pour vous sortir de situations difficiles. Gagnez des pièces en effaçant des tuiles." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Gebruik Hint, Schud, Joker en Bom om uit moeilijke situaties te komen. Verdien munten door tegels te wissen." } }
      }
    },
