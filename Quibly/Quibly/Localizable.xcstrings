    },
    "Swipe smart, clear the board, and chase the high score. Good luck!" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wische clever, leere das Brett und jage den Highscore. Viel Glück!" } },
